<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brown_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:text="PinkStream"
            android:textColor="@color/pink_primary"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Seu streaming comfy, girlie e cheio de personalidade."
            android:textColor="@color/text_soft"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:background="@color/brown_medium"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Entrar"
                android:textColor="@color/text_light"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Acesse sua conta para continuar navegando."
                android:textColor="@color/text_soft"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/edtEmailLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:backgroundTint="@color/pink_primary"
                android:hint="E-mail"
                android:inputType="textEmailAddress"
                android:textColor="@color/text_light"
                android:textColorHint="@color/text_soft" />

            <EditText
                android:id="@+id/edtSenhaLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/pink_primary"
                android:hint="Senha"
                android:inputType="textPassword"
                android:textColor="@color/text_light"
                android:textColorHint="@color/text_soft" />

            <TextView
                android:id="@+id/txtStatusLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Entre para ver seus conteúdos, playlists e perfil."
                android:textColor="@color/text_soft"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnEntrarLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:backgroundTint="@color/pink_strong"
                android:text="Entrar"
                android:textColor="@color/white" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
