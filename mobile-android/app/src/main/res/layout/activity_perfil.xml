<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brown_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <Button
            android:id="@+id/btnVoltarPerfil"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Voltar"
            android:backgroundTint="@color/pink_soft"
            android:textColor="@color/brown_dark"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Meu perfil"
            android:textColor="@color/pink_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Seus dados e atividade no app"
            android:textColor="@color/text_soft"
            android:textSize="15sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/brown_medium"
            android:padding="20dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/txtNomePerfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jessica Daddato"
                android:textColor="@color/text_light"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtEmailPerfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="jessica@email.com"
                android:textColor="@color/text_soft"
                android:textSize="15sp"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/brown_medium"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resumo da conta"
                android:textColor="@color/text_light"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/txtQuantidadeCurtidas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Conteudos curtidos: 0"
                android:textColor="@color/text_soft"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/txtQuantidadePlaylists"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Playlists disponiveis: 3"
                android:textColor="@color/text_soft"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/txtQuantidadeCriadores"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Criadores seguidos: 0"
                android:textColor="@color/text_soft"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnEditarPerfil"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Editar perfil"
            android:backgroundTint="@color/pink_primary"
            android:textColor="@color/brown_dark"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnVerCurtidas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ver curtidas"
            android:backgroundTint="@color/pink_soft"
            android:textColor="@color/brown_dark" />

        <Button
            android:id="@+id/btnSairPerfil"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Sair da conta"
            android:backgroundTint="@color/pink_strong"
            android:textColor="@color/white" />

    </LinearLayout>
</ScrollView>
